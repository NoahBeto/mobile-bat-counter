[workspace]
authors = ["ssunsonic <erictsun02@gmail.com>"]
channels = ["conda-forge"]
description = "Add a short description here"
name = "2025_lagattuta_bats"
platforms = ["linux-64"]
version = "0.1.0"

[tasks]

[system-requirements]
cuda = "12.6"

[dependencies]
cuda = ">=12.6.2,<13"
pytorch = {version=">=2.5.1,<3", build="*cuda*"}
ultralytics = ">=8.3.62,<9"
albumentations = ">=2.0.3,<3"
torchvision = ">=0.20.1,<0.21"
scikit-image = ">=0.25.1,<0.26"
filterpy = ">=1.4.5,<2"
opencv = ">=4.11.0,<5"
ipdb = ">=0.13.13,<0.14"
ruff = ">=0.9.6,<0.10"
pandas = ">=2.2.3,<3"
ipython = ">=8.32.0,<9"
numpy = ">=1.26,<2"
scipy = ">=1.11,<2"
ffmpeg = "*"
matplotlib = ">=3.8,<4"
lap = "*"

[pypi-dependencies]
megadetector = ">=5.0.25, <6"
